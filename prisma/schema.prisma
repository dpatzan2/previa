generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PLAYER
}

enum MatchStage {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMIFINAL
  THIRD_PLACE
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

enum PickSide {
  HOME
  AWAY
}

enum RoomMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum RoomStatus {
  ACTIVE
  ARCHIVED
}

enum TournamentType {
  WORLD_CUP
  INTERNATIONAL_CUP
  CLUB_TOURNAMENT
  DOMESTIC_LEAGUE
  CUSTOM
}

enum RoomConfigPreset {
  BASIC
  INTERMEDIATE
  COMPLETE
  CUSTOM
}

enum RoomDeadlineMode {
  PER_MATCH
  PHASE
}

enum CompetitionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CompetitionPhaseFormat {
  GROUP
  KNOCKOUT
  LEAGUE
}

model User {
  id                     String                 @id @default(cuid())
  username               String                 @unique
  displayName            String
  passwordHash           String
  role                   Role                   @default(PLAYER)
  isActive               Boolean                @default(true)
  canParticipate         Boolean                @default(true)
  sessions               Session[]
  predictions            Prediction[]
  predictionAnswers      PredictionAnswer[]
  ownedRooms             Room[]                 @relation("RoomOwner")
  roomMembers            RoomMember[]
  roomLeaderboardEntries RoomLeaderboardEntry[]
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Team {
  id             String       @id @default(cuid())
  name           String       @unique
  normalizedName String       @unique
  groupCode      String?
  logoUrl        String?
  homeMatches    Match[]      @relation("HomeTeam")
  awayMatches    Match[]      @relation("AwayTeam")
  actualWins     Match[]      @relation("ActualWinner")
  predictions    Prediction[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Competition {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  type      TournamentType
  status    CompetitionStatus  @default(DRAFT)
  season    String?
  timezone  String             @default("America/Guatemala")
  startsAt  DateTime?
  endsAt    DateTime?
  phases    CompetitionPhase[]
  teams     CompetitionTeam[]
  matches   CompetitionMatch[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([status])
  @@index([type])
}

model CompetitionPhase {
  id            String                 @id @default(cuid())
  competitionId String
  name          String
  stage         MatchStage?
  format        CompetitionPhaseFormat
  sortOrder     Int                    @default(0)
  groupCode     String?
  startsAt      DateTime?
  endsAt        DateTime?
  competition   Competition            @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  matches       CompetitionMatch[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@unique([competitionId, sortOrder])
  @@index([competitionId])
  @@index([format])
}

model CompetitionTeam {
  id             String             @id @default(cuid())
  competitionId  String
  name           String
  normalizedName String
  groupCode      String?
  logoUrl        String?
  competition    Competition        @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  homeMatches    CompetitionMatch[] @relation("CompetitionHomeTeam")
  awayMatches    CompetitionMatch[] @relation("CompetitionAwayTeam")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([competitionId, normalizedName])
  @@index([competitionId])
  @@index([groupCode])
}

model CompetitionMatch {
  id              String            @id @default(cuid())
  competitionId   String
  phaseId         String?
  matchNumber     Int?
  kickoffAt       DateTime?
  venue           String?
  homeTeamId      String?
  awayTeamId      String?
  homePlaceholder String?
  awayPlaceholder String?
  status          MatchStatus       @default(SCHEDULED)
  homeScore       Int?
  awayScore       Int?
  competition     Competition       @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  phase           CompetitionPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  homeTeam        CompetitionTeam?  @relation("CompetitionHomeTeam", fields: [homeTeamId], references: [id])
  awayTeam        CompetitionTeam?  @relation("CompetitionAwayTeam", fields: [awayTeamId], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([competitionId, matchNumber])
  @@index([competitionId])
  @@index([phaseId])
  @@index([kickoffAt])
}

model Match {
  id                 String              @id @default(cuid())
  matchNumber        Int                 @unique
  stage              MatchStage
  groupCode          String?
  dateLabel          String?
  timeLabel          String?
  kickoffAt          DateTime?
  venue              String?
  venueShort         String?
  homeTeamId         String?
  awayTeamId         String?
  homePlaceholder    String?
  awayPlaceholder    String?
  homeScore          Int?
  awayScore          Int?
  actualWinnerTeamId String?
  actualWinnerSide   PickSide?
  actualWinnerLabel  String?
  status             MatchStatus         @default(SCHEDULED)
  homeTeam           Team?               @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam           Team?               @relation("AwayTeam", fields: [awayTeamId], references: [id])
  actualWinnerTeam   Team?               @relation("ActualWinner", fields: [actualWinnerTeamId], references: [id])
  predictions        Prediction[]
  predictionAnswers  PredictionAnswer[]
  marketResults      MatchMarketResult[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([stage])
  @@index([kickoffAt])
}

model Room {
  id                   String                 @id @default(cuid())
  name                 String
  accessCode           String                 @unique
  tournamentType       TournamentType
  tournamentName       String
  externalTournamentId String?
  configPreset         RoomConfigPreset       @default(BASIC)
  deadlineMode         RoomDeadlineMode       @default(PER_MATCH)
  deadlineHoursBefore  Int                    @default(1)
  status               RoomStatus             @default(ACTIVE)
  ownerId              String
  owner                User                   @relation("RoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members              RoomMember[]
  ruleSet              RoomRuleSet?
  predictions          Prediction[]
  predictionAnswers    PredictionAnswer[]
  leaderboardEntries   RoomLeaderboardEntry[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([tournamentType])
}

model RoomMember {
  id        String         @id @default(cuid())
  roomId    String
  userId    String
  role      RoomMemberRole @default(MEMBER)
  joinedAt  DateTime       @default(now())
  room      Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([roomId, userId])
  @@index([userId])
  @@index([role])
}

model RoomRuleSet {
  id                 String           @id @default(cuid())
  roomId             String           @unique
  preset             RoomConfigPreset @default(BASIC)
  exactScorePoints   Int              @default(3)
  outcomePoints      Int              @default(1)
  advancePickPoints  Int              @default(1)
  enabledMarkets     Json
  customMarketConfig Json?
  room               Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Prediction {
  id                    String    @id @default(cuid())
  userId                String
  matchId               String
  roomId                String?
  predictedHomeScore    Int?
  predictedAwayScore    Int?
  predictedWinnerTeamId String?
  predictedWinnerSide   PickSide?
  points                Int       @default(0)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  match                 Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  room                  Room?     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  predictedWinnerTeam   Team?     @relation(fields: [predictedWinnerTeamId], references: [id])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([roomId, userId, matchId])
  @@index([userId, matchId])
  @@index([matchId])
  @@index([roomId])
}

model PredictionAnswer {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  matchId   String
  marketKey String
  value     Json
  points    Int      @default(0)
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roomId, userId, matchId, marketKey])
  @@index([roomId, matchId])
  @@index([userId])
  @@index([marketKey])
}

model MatchMarketResult {
  id        String   @id @default(cuid())
  matchId   String
  marketKey String
  value     Json
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, marketKey])
  @@index([marketKey])
}

model RoomLeaderboardEntry {
  roomId          String
  userId          String
  totalPoints     Int      @default(0)
  predictionCount Int      @default(0)
  room            Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt       DateTime @updatedAt

  @@id([roomId, userId])
  @@index([roomId, totalPoints(sort: Desc), userId])
  @@index([userId])
}

model ScoringSettings {
  id                    String   @id @default("default")
  groupExactPoints      Int      @default(3)
  groupOutcomePoints    Int      @default(2)
  knockoutAdvancePoints Int      @default(3)
  updatedAt             DateTime @updatedAt
}
